{
  "description": "Native toolchain bundled with Claude Manager so tools work with no manual download.",
  "tools": {
    "rtk": {
      "role": "input compression (Rust Token Killer)",
      "bundled": { "mac-arm64": "mac-arm64/rtk", "mac-x64": "mac-x64/rtk", "win-x64": "win-x64/rtk.exe" },
      "version": "0.43.0",
      "fallbackInstall": "curl -fsSL https://raw.githubusercontent.com/reachingforthejack/rtk/main/install.sh | sh"
    },
    "caveman": {
      "role": "output compression (Claude Code plugin)",
      "bundledMarketplace": "caveman",
      "localInstall": "node caveman/bin/install.js --only claude",
      "fallbackInstall": "npx -y github:JuliusBrussee/caveman --only claude"
    },
    "claude": {
      "role": "Claude Code CLI (Anthropic — not redistributable, auto-installed once if missing)",
      "bundled": {},
      "fallbackInstall": "curl -fsSL https://claude.ai/install.sh | bash"
    },
    "headroom": {
      "role": "optional compression proxy (Python)",
      "bundled": {},
      "fallbackInstall": "pipx install 'headroom-ai[all]'"
    }
  }
}
