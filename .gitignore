# ---- macOS ----
.DS_Store

# ---- Swift / SwiftPM build artifacts (regenerated by build-mac.sh) ----
MAC/.build/
.build/
*.xcodeproj
DerivedData/

# ---- Built app bundle (regenerated by build-mac.sh) ----
*.app/

# ---- Windows build output (compiled by Hydra.bat) ----
WINDOWS/*.exe
!WINDOWS/Hydra.exe
*.exe
*.dll
*.pdb

# ---- Node (in case any SaaS scaffolding lands here) ----
node_modules/
npm-debug.log*

# ---- Secrets ----
.env
.env.*
!.env.*.example
